SUPABASE_URL=
# Use the service role key on the server (never expose it to browsers).
SUPABASE_SERVICE_ROLE_KEY=

SUPABASE_STORAGE_BUCKET=

# Optional: allow CORS for your Vite dev server
FRONTEND_ORIGIN=

# --- AI / Pinecone (sentence-transformers/all-MiniLM-L6-v2 => 384-d vectors) ---
# Your Pinecone index must use dimension 384 for this model (not 1536).
PINECONE_API_KEY= 
PINECONE_INDEX_NAME=legal-doc-embeddings
# Optional: serverless index host from Pinecone dashboard if needed
PINECONE_HOST=
PINECONE_EXPECTED_DIMENSION=384

# Optional overrides
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
# After install: python -m spacy download en_core_web_sm
  
# Gemini summarization  
GEMINI_API_KEY=  
GEMINI_MODEL_NAME=gemini-2.5-pro  
GEMINI_MAP_MODEL_NAME=gemini-2.5-flash
GEMINI_REDUCE_MODEL_NAME=gemini-2.5-pro
GEMINI_TIMEOUT_SECONDS=45  
GEMINI_MAX_RETRIES=4  
GEMINI_RATE_LIMIT_BACKOFF_SECONDS=8  
GEMINI_CONCURRENCY=4  
GEMINI_CACHE_SIZE=256 
GEMINI_MAX_CHUNKS=15
GEMINI_MAP_TIMEOUT_SECONDS=25
GEMINI_MAP_MAX_RETRIES=2
GEMINI_REDUCE_TIMEOUT_SECONDS=45
GEMINI_REDUCE_MAX_RETRIES=3
